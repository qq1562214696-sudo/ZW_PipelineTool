<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZW_PipelineTool.MainWindow"
        Title="ZW 流水线工具"
        Width="500" Height="600"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

  <!-- 最外层 ScrollViewer：整个窗口内容可上下滚动 -->
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="20" Spacing="12">
      <CheckBox Content="窗口置顶" 
                Checked="ToggleTopmost_Checked" 
                Unchecked="ToggleTopmost_Unchecked" 
                IsChecked="True"/>

      <!-- MaxScript 按钮区域 -->
      <TextBlock Text="QF 工具" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
      <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,5,0,10">
        <Button Grid.Row="0" Grid.Column="0" Content="规范模型" Click="OnScriptButton_Click" Margin="2"/>
        <Button Grid.Row="0" Grid.Column="1" Content="导出FBX(当前)" Click="OnScriptButton_Click" Margin="2"/>
        <Button Grid.Row="0" Grid.Column="2" Content="导出（贴图+FBX）" Click="OnScriptButton_Click" Margin="2"/>
        <Button Grid.Row="1" Grid.Column="0" Content="选择多边面" Click="OnScriptButton_Click" Margin="2"/>
        <Button Grid.Row="1" Grid.Column="1" Content="选择法线翻转的面" Click="OnScriptButton_Click" Margin="2"/>
        <Button Grid.Row="1" Grid.Column="2" Content="面数检查" Click="OnScriptButton_Click" Margin="2"/>
        <Button Grid.Row="2" Grid.Column="0" Content="Mesh01_重命名" Click="OnScriptButton_Click" Margin="2"/>
      </Grid>

      <!-- 日志区域：加 ScrollViewer + 固定高度，内容超长自动滚动 -->
      <Expander Header="日志（可复制）" IsExpanded="True" Margin="0,10,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled" 
                      Height="200">
          <TextBox x:Name="LogBox" 
                   AcceptsReturn="True" 
                   IsReadOnly="True" 
                   TextWrapping="Wrap" 
                   FontFamily="Consolas, Courier New, monospace"
                   Padding="8"/>
        </ScrollViewer>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</Window>