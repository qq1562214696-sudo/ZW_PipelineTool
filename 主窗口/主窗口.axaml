<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZW_PipelineTool.主窗口"
        Title="创宇极 - 多项目整合代理工具 v1.0    作者：周维    VX:1562214696"
        Width="480"
        Height="560"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        FontSize="12">

    <Window.Styles>
        <!-- 样式保持不变 -->
        <Style Selector="Button">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="8,-5"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Expander">
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Expander /template/ ToggleButton#PART_Header">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="Expander /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Expander /template/ ContentPresenter#PART_HeaderPresenter TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Expander[ExpandDirection=Down] /template/ Path">
            <Setter Property="Margin" Value="4,0,8,0"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="4,1"/>
        </Style>

        <Style Selector="TextBox /template/ TextPresenter">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
    </Window.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8" Spacing="2">

            <Expander Header="工具基本设置" IsExpanded="True">
                <StackPanel Margin="0,2,0,0" Spacing="2">
                    <CheckBox x:Name="置顶CheckBox"
                              Content="窗口始终置顶"
                              IsChecked="True"/>
                    <CheckBox x:Name="开机自启CheckBox"
                              Content="开机自动启动（待实现）"
                              IsChecked="False"/>
                              <StackPanel>
                                    <!-- 其他控件 -->
                                    <Button Content="打开文件收集器" Click="打开文件收集器_Click" HorizontalAlignment="Center" Margin="5"/>
                              </StackPanel>
                </StackPanel>
            </Expander>

            <Expander Header="运行日志（支持复制）" IsExpanded="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Height="110">
                    <TextBox x:Name="LogBox"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas, Courier New, monospace"
                             Height="100"
                             Padding="4,2"/>
                </ScrollViewer>
            </Expander>

            <Expander Header="QF 项目流程" IsExpanded="True">
                <StackPanel Margin="0,2,0,0" Spacing="2">
                    <Expander Header="首次初始化（只需设置一次）" IsExpanded="True">
                        <StackPanel Spacing="2">
                            <TextBox x:Name="QF_MaxPathInput" 
                                     Watermark="在此粘贴 Max 主文件名（不含路径）"
                                     Height="20" Padding="4,1"/>
                            <TextBox x:Name="QF_UnityPathInput" 
                                     Watermark="在此粘贴 Unity 主文件名（不含路径）"
                                     Height="20" Padding="4,1"/>
                            <Button x:Name="QF_初始化按钮" 
                                    Content="执行初始化"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="3ds Max 常用工具" IsExpanded="True">
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">
                            <Button x:Name="规范模型命名Btn" Grid.Row="0" Grid.Column="0" Content="规范模型命名" Tag="规范模型.ms"/>
                            <Button x:Name="导出当前选中为FBXBtn" Grid.Row="0" Grid.Column="1" Content="导出当前选中为FBX" Tag="导出FBX(当前).ms"/>
                            <Button x:Name="导出贴图加FBXBtn" Grid.Row="0" Grid.Column="2" Content="导出贴图+FBX" Tag="导出（贴图+FBX）.ms"/>
                            <Button x:Name="选择多边面物体Btn" Grid.Row="1" Grid.Column="0" Content="选择多边面物体" Tag="选择多边面.ms"/>
                            <Button x:Name="选择法线翻转的面Btn" Grid.Row="1" Grid.Column="1" Content="选择法线翻转的面" Tag="选择法线翻转的面.ms"/>
                            <Button x:Name="快速面数检查Btn" Grid.Row="1" Grid.Column="2" Content="快速面数检查" Tag="面数检查.ms"/>
                            <Button x:Name="Mesh01批量重命名Btn" Grid.Row="2" Grid.Column="0" Content="Mesh01 批量重命名" Tag="Mesh01_重命名.ms"/>
                        </Grid>
                    </Expander>

                    <Expander Header="Unity 常用工具" IsExpanded="True">
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,2,0,0">
                            <Button x:Name="Unity初始化Btn" Grid.Row="0" Grid.Column="0" Content="Unity 初始化（待实现）"/>
                            <Button x:Name="打开头像编辑器Btn" Grid.Row="0" Grid.Column="1" Content="打开 Avatar 编辑器"/>
                            <Button x:Name="复制并导出Btn" Grid.Row="0" Grid.Column="2" Content="复制选中并打开导出窗口"/>
                            <Button x:Name="粘贴Max名称Btn" Grid.Row="1" Grid.Column="0" Content="粘贴 Max 文件名到 Unity"/>
                            <Button x:Name="文件标准化Btn" Grid.Row="1" Grid.Column="1" Content="一键规范文件结构"/>
                            <Button x:Name="批量导出Btn" Grid.Row="1" Grid.Column="2" Content="一键批量导出资产"/>
                            <Button x:Name="清空Max名称Btn" Grid.Row="2" Grid.Column="0" Content="清空 Unity 中的 Max 名称列表"/>
                        </Grid>
                    </Expander>
                </StackPanel>
            </Expander>

            <Expander Header="小岛植物 项目" IsExpanded="True">
                <StackPanel Margin="0,2,0,0" Spacing="2">
                    <TextBox x:Name="Island_MaxPathInput" 
                             Watermark="在此粘贴小岛植物 Max 主文件名"
                             Height="20" Padding="4,1"/>
                    <TextBox x:Name="Island_UnityPathInput" 
                             Watermark="在此粘贴小岛植物 Unity 主文件名"
                             Height="20" Padding="4,1"/>

                    <Expander Header="3ds Max 工具（小岛植物专用）" IsExpanded="True">
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">
                            <Button x:Name="小岛_规范模型命名Btn" Grid.Row="0" Grid.Column="0" Content="规范模型命名（待实现）" Tag="规范模型.ms"/>
                            <Button x:Name="小岛_导出当前为FBXBtn" Grid.Row="0" Grid.Column="1" Content="导出当前为FBX（待实现）" Tag="导出FBX(当前).ms"/>
                            <Button x:Name="小岛_导出贴图加FBXBtn" Grid.Row="0" Grid.Column="2" Content="导出贴图+FBX（待实现）" Tag="导出（贴图+FBX）.ms"/>
                            <Button x:Name="小岛_选择多边面Btn" Grid.Row="1" Grid.Column="0" Content="选择多边面（待实现）" Tag="选择多边面.ms"/>
                            <Button x:Name="小岛_选择法线翻转Btn" Grid.Row="1" Grid.Column="1" Content="选择法线翻转的面（待实现）" Tag="选择法线翻转的面.ms"/>
                            <Button x:Name="小岛_面数检查Btn" Grid.Row="1" Grid.Column="2" Content="面数检查（待实现）" Tag="面数检查.ms"/>
                            <Button x:Name="小岛_Mesh01重命名Btn" Grid.Row="2" Grid.Column="0" Content="Mesh01 批量重命名（待实现）" Tag="Mesh01_重命名.ms"/>
                        </Grid>
                    </Expander>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Window>