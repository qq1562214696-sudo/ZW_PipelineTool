<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:ZW_PipelineTool"
        x:Class="ZW_PipelineTool.主窗口"
        x:Name="ThisWindow"
        x:CompileBindings="False"
        Title="创宇极 - 多项目整合代理工具 v1.0    作者：周维    VX:1562214696"
        Width="500" Height="750"
        WindowStartupLocation="CenterScreen"
        FontSize="12">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="8,-5"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Expander">
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Expander /template/ ToggleButton#PART_Header">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="Expander /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Expander /template/ ContentPresenter#PART_HeaderPresenter TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Expander[ExpandDirection=Down] /template/ Path">
            <Setter Property="Margin" Value="4,0,8,0"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="4,1"/>
        </Style>

        <Style Selector="TextBox /template/ TextPresenter">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
    </Window.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8" Spacing="2">

            <!-- 工具基本设置 -->
            <Expander x:Name="工具基本设置" Header="工具基本设置" IsExpanded="True">
                <StackPanel Margin="0,2,0,0" Spacing="2">
                    <CheckBox x:Name="置顶CheckBox"
                              Content="窗口始终置顶"
                              IsChecked="{Binding Topmost, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <CheckBox x:Name="开机自启CheckBox"
                            Content="开机自动启动"
                            IsChecked="{Binding 开机自启, Mode=TwoWay}"/>
                        <StackPanel>
                        <Button Content="打开文件复制器" 
                                Click="打开文件复制器_Click" 
                                HorizontalAlignment="Center" Margin="5">
                            <ToolTip.Tip>
                                <ToolTip>
                                    <TextBlock TextWrapping="Wrap" MaxWidth="300">
                                        用于代码开发使用，功能是一键将拖入的 任何格式 文本文件 的内容复制到剪切板
                                    </TextBlock>
                                </ToolTip>
                            </ToolTip.Tip>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- 运行日志（关键修复在这里） -->
            <Expander x:Name="运行日志" Header="运行日志（支持复制）" IsExpanded="False">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- 日志列表 -->
                    <ScrollViewer Grid.Column="0" 
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                Height="160">
                        <ListBox x:Name="LogListBox"
                                ItemsSource="{Binding 日志列表}"
                                Background="Transparent"
                                BorderThickness="0"
                                SelectionMode="Multiple"          
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="local:日志数据">
                                    <TextBlock Text="{Binding Message}"
                                            Foreground="{Binding Color}"
                                            TextWrapping="Wrap"
                                            FontFamily="Consolas, Courier New, monospace"
                                            Margin="2,1"/> 
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            
                            <!-- 右键菜单 -->
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="复制选中日志" Click="复制选中日志_Click"/>
                                    <MenuItem Header="清空全部日志" Click="清空日志_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </ScrollViewer>
                    
                    <!-- 右侧按钮栏 -->
                    <StackPanel Grid.Column="1" 
                                Orientation="Vertical" 
                                Spacing="4" 
                                Margin="4,0,0,0"
                                VerticalAlignment="Top">
                        <Button Content="清空" 
                                Width="60" Height="24" 
                                Click="清空日志_Click"/>
                        <Button Content="复制" 
                                Width="60" Height="24" 
                                Click="复制全部日志_Click"/>
                    </StackPanel>
                </Grid>
            </Expander>

            <Expander Header="QF 项目" IsExpanded="True">
                <StackPanel Margin="0,2,0,0" Spacing="2">
                    <Expander Header="初始化（只需设置一次）" IsExpanded="True">
                        <StackPanel Spacing="2">
                            <TextBox x:Name="QF_MaxPathInput" 
                                     Watermark="Max 2014 快捷方式或exe（拖入或手动输入）"
                                     Height="20" Padding="4,1"/>
                            <TextBox x:Name="QF_UnityPathInput" 
                                     Watermark="Unity Assets路径（拖入或手动输入）"
                                     Height="20" Padding="4,1"/>
                            <Button x:Name="QF_初始化按钮" 
                                    Content="执行初始化"
                                    Click="初始化按钮_点击"/>
                        </StackPanel>
                    </Expander>
                            <!-- ///////////////////////这里需要加一个处理文件储存列表，用于后续规范的使用 -->
                    <Expander Header="3ds Max 常用工具" IsExpanded="True">
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">

                            <Button x:Name="规范模型Btn" Grid.Row="0" Grid.Column="0" 
                                    Content="规范模型" Tag="规范模型.ms" Click="脚本按钮_点击">
                                <ToolTip.Tip>
                                    <ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="300">
                                            <Run Text="包含功能：" />
                                            <LineBreak/>
                                            <Run Text="1.贴原画到&quot;原画&quot;Plane、自动调整宽高比例" />
                                            <LineBreak/>
                                            <Run Text="2.清空、创建、命名材质" />
                                            <LineBreak/>
                                            <Run Text="3.通道贴图、命名、贴图条带" />
                                            <LineBreak/>
                                            <Run Text="4.重置轴心、缩放归一、90度旋转、纠正链接" />
                                            <LineBreak/>
                                            <Run Text="5.删除模型动画、多余 UV 通道、模型贴材质" />
                                        </TextBlock>
                                    </ToolTip>
                                </ToolTip.Tip>
                            </Button>

                            <Button x:Name="导出FBXBtn" Grid.Row="0" Grid.Column="1" 
                                    Content="导出FBX(当前)" Tag="导出FBX(当前).ms" Click="脚本按钮_点击"/>

                            <Button x:Name="导出贴图加FBXBtn" Grid.Row="0" Grid.Column="2" 
                                    Content="导出（贴图+FBX）" Tag="导出（贴图+FBX）.ms" Click="脚本按钮_点击"/>

                            <Button x:Name="选择多边面Btn" Grid.Row="1" Grid.Column="0" 
                                    Content="选择多边面" Tag="选择多边面.ms" Click="脚本按钮_点击"/>

                            <Button x:Name="选择法线翻转的面Btn" Grid.Row="1" Grid.Column="1" 
                                    Content="选择法线翻转的面" Tag="选择法线翻转的面.ms" Click="脚本按钮_点击"/>

                            <Button x:Name="面数检查Btn" Grid.Row="1" Grid.Column="2" 
                                    Content="面数检查" Tag="面数检查.ms" Click="脚本按钮_点击"/>

                            <Button x:Name="Mesh01_重命名Btn" Grid.Row="2" Grid.Column="0" 
                                    Content="Mesh01_重命名" Tag="Mesh01_重命名.ms" Click="脚本按钮_点击"/>

                        </Grid>
                    </Expander>

                    <Expander Header="Unity 常用工具" IsExpanded="True">
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,2,0,0">
                            <Button x:Name="Unity初始化Btn" Grid.Row="0" Grid.Column="0" 
                                    Content="Unity 初始化（待实现）" Click="初始化按钮_点击"/>
                            <Button x:Name="打开头像编辑器Btn" Grid.Row="0" Grid.Column="1" 
                                    Content="打开 Avatar 编辑器" Click="打开头像编辑器按钮_点击"/>
                            <Button x:Name="复制并导出Btn" Grid.Row="0" Grid.Column="2" 
                                    Content="复制选中并打开导出窗口" Click="复制并导出按钮_点击"/>
                            <Button x:Name="粘贴Max名称Btn" Grid.Row="1" Grid.Column="0" 
                                    Content="粘贴 Max 文件名到 Unity" Click="粘贴Max名称按钮_点击"/>
                            <Button x:Name="文件标准化Btn" Grid.Row="1" Grid.Column="1" 
                                    Content="一键规范文件结构" Click="文件标准化按钮_点击"/>
                            <Button x:Name="批量导出Btn" Grid.Row="1" Grid.Column="2" 
                                    Content="一键批量导出资产" Click="批量导出按钮_点击"/>
                            <Button x:Name="清空Max名称Btn" Grid.Row="2" Grid.Column="0" 
                                    Content="清空 Unity 中的 Max 名称列表" Click="清空Max名称按钮_点击"/>
                        </Grid>
                    </Expander>
                </StackPanel>
            </Expander>

            <Expander Header="小岛植物 项目" IsExpanded="True">
                <StackPanel Margin="0,2,0,0" Spacing="2">
                    <TextBox x:Name="Island_MaxPathInput" 
                             Watermark="在此粘贴小岛植物 Max 主文件名"
                             Height="20" Padding="4,1"/>
                    <TextBox x:Name="Island_UnityPathInput" 
                             Watermark="在此粘贴小岛植物 Unity 主文件名"
                             Height="20" Padding="4,1"/>

                    <Expander Header="3ds Max 工具（小岛植物专用）" IsExpanded="True">
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">
                            <Button x:Name="小岛_规范模型命名Btn" Grid.Row="0" Grid.Column="0" 
                                    Content="规范模型命名（待实现）" Tag="规范模型.ms" Click="脚本按钮_点击"/>
                            <Button x:Name="小岛_导出当前为FBXBtn" Grid.Row="0" Grid.Column="1" 
                                    Content="导出当前为FBX（待实现）" Tag="导出FBX(当前).ms" Click="脚本按钮_点击"/>
                            <Button x:Name="小岛_导出贴图加FBXBtn" Grid.Row="0" Grid.Column="2" 
                                    Content="导出贴图+FBX（待实现）" Tag="导出（贴图+FBX）.ms" Click="脚本按钮_点击"/>
                            <Button x:Name="小岛_选择多边面Btn" Grid.Row="1" Grid.Column="0" 
                                    Content="选择多边面（待实现）" Tag="选择多边面.ms" Click="脚本按钮_点击"/>
                            <Button x:Name="小岛_选择法线翻转Btn" Grid.Row="1" Grid.Column="1" 
                                    Content="选择法线翻转的面（待实现）" Tag="选择法线翻转的面.ms" Click="脚本按钮_点击"/>
                            <Button x:Name="小岛_面数检查Btn" Grid.Row="1" Grid.Column="2" 
                                    Content="面数检查（待实现）" Tag="面数检查.ms" Click="脚本按钮_点击"/>
                            <Button x:Name="小岛_Mesh01重命名Btn" Grid.Row="2" Grid.Column="0" 
                                    Content="Mesh01 批量重命名（待实现）" Tag="Mesh01_重命名.ms" Click="脚本按钮_点击"/>
                        </Grid>
                    </Expander>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Window>