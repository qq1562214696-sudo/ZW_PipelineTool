<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZW_PipelineTool.MainWindow"
        Title="ZW 流水线工具"
        Width="400" Height="250"
        WindowStartupLocation="CenterScreen"
        Topmost="True">  <!-- 默认置顶，可由 CheckBox 动态控制 -->

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
        <TextBox Name="MaxPathTextBox" Width="300" IsReadOnly="True"
                 Watermark="拖入 Max 可执行文件或快捷方式"
                 DragDrop.AllowDrop="True"
                 DragDrop.Drop="MaxPathTextBox_Drop"/>
        <Button Content="初始化" Click="OnInitializeClick" Padding="20,10" Width="200"/>
        <Button Content="测试" Click="OnTestClick" Padding="20,10" Width="200"/>
        <CheckBox Content="窗口置顶" Checked="ToggleTopmost_Checked" Unchecked="ToggleTopmost_Unchecked" IsChecked="True"/>
    </StackPanel>
</Window>